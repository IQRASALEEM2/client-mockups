    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <script>
        // Header scroll effect
        window.addEventListener('scroll', () => {
            document.querySelector('header').classList.toggle('header-scrolled', window.scrollY > 60);
        });

        // Reveal on scroll
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        // Counter animation
        function animateCounter(el) {
            const target = +el.dataset.target;
            const duration = 2000;
            const step = target / (duration / 16);
            let current = 0;
            const id = setInterval(() => {
                current += step;
                if (current >= target) {
                    el.textContent = target + (el.dataset.target === "100" ? "%" : "+");
                    clearInterval(id);
                } else {
                    el.textContent = Math.floor(current) + "+";
                }
            }, 16);
        }

        const statsObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.querySelectorAll('[data-target]').forEach(animateCounter);
                    statsObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.3 });

        document.querySelectorAll('.stats-grid').forEach(el => statsObserver.observe(el));

        // Hamburger menu
        const hb = document.getElementById('hamburger'), mm = document.getElementById('mobileMenu');
        hb.addEventListener('click', () => {
            const isOpen = mm.style.maxHeight && mm.style.maxHeight !== '0px';
            mm.style.maxHeight = isOpen ? '0px' : '500px';
            hb.textContent = isOpen ? '☰' : '✕';
        });

        // Sliders Logic
        function setupSlider(trackId, prevId, nextId, dotContainerId, totalCards) {
            const track = document.getElementById(trackId);
            const prev = document.getElementById(prevId);
            const next = document.getElementById(nextId);
            const dotContainer = document.getElementById(dotContainerId);
            let current = 0;

            const getVisibleCards = () => window.innerWidth >= 1024 ? 3 : window.innerWidth >= 768 ? 2 : 1;

            const updateSlider = () => {
                const vis = getVisibleCards();
                const max = totalCards - vis;
                current = Math.max(0, Math.min(current, max));
                const card = track.children[0];
                const width = card.offsetWidth + 28;
                track.style.transform = `translateX(-${current * width}px)`;
                
                // Update dots
                const dots = dotContainer.querySelectorAll('.dot');
                dots.forEach((d, i) => d.classList.toggle('active', i === current));
            };

            prev.addEventListener('click', () => { current--; updateSlider(); });
            next.addEventListener('click', () => { current++; updateSlider(); });
            
            // Auto-advance reviews only
            if(trackId === 'reviewsTrack') {
                setInterval(() => {
                    current = (current + 1) > (totalCards - getVisibleCards()) ? 0 : current + 1;
                    updateSlider();
                }, 5000);
            }

            window.addEventListener('resize', updateSlider);
        }

        setupSlider('reviewsTrack', 'reviewsPrev', 'reviewsNext', 'reviewsDots', 5);
        setupSlider('portfolioTrack', 'portfolioPrev', 'portfolioNext', 'portfolioDots', 6);

        // Smooth scroll and active nav
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                    mm.style.maxHeight = '0px';
                    hb.textContent = '☰';
                }
            });
        });

        window.addEventListener('scroll', () => {
            const sy = window.scrollY + 100;
            document.querySelectorAll('section[id]').forEach(s => {
                const link = document.querySelector(`.nav-link[href="#${s.id}"]`);
                if (link) {
                    const active = sy >= s.offsetTop && sy < s.offsetTop + s.offsetHeight;
                    link.classList.toggle('active', active);
                }
            });
        });
    </script>
